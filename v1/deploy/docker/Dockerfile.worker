FROM golang:1.25.3 AS builder

ARG TARGETOS
ARG TARGETARCH

WORKDIR /src

RUN set -eux; \
	apt-get update; \
	apt-get install -y --no-install-recommends git ca-certificates; \
	update-ca-certificates; \
	rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} go build -o /out/worker ./cmd/worker

ARG GH_CLI_APK_VERSION

FROM debian:bookworm-slim AS runtime-base

ARG TARGETARCH
ARG TASK_CLI_VERSION=3.40.1

RUN set -eux; \
	apt-get update; \
	TRACE_EXTRAS=""; \
	GH_PACKAGE="gh"; \
	if [ "${TARGETARCH:-amd64}" = "amd64" ]; then TRACE_EXTRAS="ltrace"; fi; \
	if [ -n "${GH_CLI_APK_VERSION:-}" ]; then GH_PACKAGE="gh=${GH_CLI_APK_VERSION}"; fi; \
	apt-get install -y --no-install-recommends \
	ca-certificates \
	git \
	curl \
	wget \
	tar \
	"${GH_PACKAGE}" \
	libstdc++6 \
	libgcc-s1 \
	jq \
	yq \
	bash \
	less \
	procps \
	lsof \
	netcat-openbsd \
	dnsutils \
	iputils-ping \
	unzip \
	zip \
	ripgrep \
	fd-find \
	tree \
	make \
	findutils \
	coreutils \
	moreutils \
	file \
	vim-common \
	xxd \
	rsync \
	fzf \
	entr \
	strace \
	tcpdump \
	traceroute \
	mtr-tiny \
	sqlite3 \
	pandoc \
	shellcheck \
	shfmt \
	tini \
	${TRACE_EXTRAS}; \
	ln -sf /usr/bin/fdfind /usr/local/bin/fd; \
	update-ca-certificates; \
	rm -rf /var/lib/apt/lists/*

RUN set -eux; \
	apt-get update; \
	apt-get install -y --no-install-recommends docker.io; \
	rm -rf /var/lib/apt/lists/*

RUN set -eux; \
	case "${TARGETARCH:-amd64}" in \
	amd64) TASK_ASSET_ARCH=x64 ;; \
	arm64) TASK_ASSET_ARCH=arm64 ;; \
	*) echo "unsupported TARGETARCH for task install: ${TARGETARCH}"; exit 1 ;; \
	esac; \
	TASK_URL="https://github.com/go-task/task/releases/download/v${TASK_CLI_VERSION}/task_linux_${TASK_ASSET_ARCH}.tar.gz"; \
	curl -fsSL "${TASK_URL}" -o /tmp/task.tar.gz; \
	tar -xzf /tmp/task.tar.gz -C /tmp; \
	install -m 0755 /tmp/task /usr/local/bin/task; \
	rm -rf /tmp/task /tmp/task.tar.gz

COPY --from=builder /usr/local/go /usr/local/go

ENV PATH="/usr/local/go/bin:/root/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ENV GOBIN="/usr/local/bin"

RUN set -eux; \
	ln -sf /usr/local/go/bin/go /usr/local/bin/go; \
	ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt

RUN set -eux; \
	apt-get update; \
	apt-get install -y --no-install-recommends \
	python3 \
	python3-pip \
	python3-venv \
	nodejs \
	npm \
	openjdk-17-jdk-headless \
	ruby-full \
	php-cli \
	rustc \
	cargo \
	build-essential \
	cmake \
	pkg-config; \
	go version; \
	go install golang.org/x/tools/gopls@latest; \
	go install golang.org/x/tools/cmd/goimports@latest; \
	go install github.com/go-delve/delve/cmd/dlv@latest; \
	go install honnef.co/go/tools/cmd/staticcheck@latest; \
	go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest; \
	go install gotest.tools/gotestsum@latest; \
	go install go.uber.org/mock/mockgen@latest; \
	go install golang.org/x/vuln/cmd/govulncheck@latest; \
	rm -rf /var/lib/apt/lists/*

WORKDIR /app

FROM runtime-base AS runtime-copilot-base

ARG COPILOT_CLI_VERSION=0.0.421
ARG TARGETOS
ARG TARGETARCH

RUN set -eux; \
	if [ "${TARGETOS:-linux}" != "linux" ]; then \
	echo "unsupported TARGETOS for worker-copilot: ${TARGETOS}"; \
	exit 1; \
	fi; \
	case "${TARGETARCH:-amd64}" in \
	amd64) COPILOT_ASSET_ARCH=x64 ;; \
	arm64) COPILOT_ASSET_ARCH=arm64 ;; \
	*) echo "unsupported TARGETARCH for worker-copilot: ${TARGETARCH}"; exit 1 ;; \
	esac; \
	COPILOT_URL="https://github.com/github/copilot-cli/releases/download/v${COPILOT_CLI_VERSION}/copilot-linux-${COPILOT_ASSET_ARCH}.tar.gz"; \
	curl -fsSL "${COPILOT_URL}" -o /tmp/copilot.tar.gz; \
	tar -xzf /tmp/copilot.tar.gz -C /tmp; \
	install -m 0755 /tmp/copilot /usr/local/bin/copilot; \
	rm -rf /tmp/copilot /tmp/copilot.tar.gz

FROM runtime-copilot-base AS worker

COPY --from=builder /out/worker /app/worker

EXPOSE 8080
ENTRYPOINT ["/app/worker"]

FROM runtime-copilot-base AS worker-dev-watch

WORKDIR /src

RUN go install github.com/air-verse/air@latest

COPY go.mod go.sum ./
RUN go mod download

COPY . .

EXPOSE 8080
CMD ["air", "-c", "deploy/docker/air.worker.toml"]
