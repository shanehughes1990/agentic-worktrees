# v1 environment template (new core bootstrap)

# Shared runtime
APP_PORT=8080
DATABASE_DSN=postgres://postgres:postgres@127.0.0.1:5432/agentic_orchestrator?sslmode=disable
REDIS_URL=redis://redis:6379/0
SHUTDOWN_TIMEOUT=15s
HEALTH_LIVE_PATH=/live
HEALTH_READY_PATH=/ready

# OpenTelemetry
OTEL_DEPLOYMENT_ENVIRONMENT=local
# Optional (defaults by runtime if unset: API=agentic-api, Worker=agentic-worker)
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Task engine
TASK_ENGINE_BACKEND=asynq
TASK_ENGINE_REDIS_ADDRESS=redis:6379
TASK_ENGINE_REDIS_PASSWORD=
TASK_ENGINE_REDIS_DATABASE=0
TASK_ENGINE_CONCURRENCY=10
TASK_ENGINE_SCM_QUEUE=scm

# SCM

# API runtime
API_GRAPHQL_PATH=/query
API_PLAYGROUND_PATH=/
API_ENABLE_PLAYGROUND=true

# Worker runtime
APPLICATION_ROOT_DIRECTORY=.agentic-orchestrator
# When running worker as a separate process, override APP_PORT (for example 8081)
