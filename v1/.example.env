# v1 environment template

# Service identity
SERVICE_NAME=agentic-orchestrator
APP_ENV=local
SERVICE_VERSION=development

# Logging
LOG_FORMAT=text
LOG_LEVEL=info
LOG_PRETTY_JSON=false

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Health endpoints
HEALTH_LIVE_PATH=/live
HEALTH_READY_PATH=/ready
SHUTDOWN_TIMEOUT=15s

# Task engine
TASK_ENGINE_BACKEND=asynq
TASK_ENGINE_REDIS_ADDRESS=127.0.0.1:6379
TASK_ENGINE_REDIS_PASSWORD=
TASK_ENGINE_REDIS_DATABASE=0
TASK_ENGINE_CONCURRENCY=10
TASK_ENGINE_INGESTION_QUEUE=ingestion
TASK_ENGINE_SCM_QUEUE=scm

# Tracker
TRACKER_LOCAL_JSON_BASE_PATH=.

# SCM
SCM_PROVIDER=github
SCM_GITHUB_TOKEN=
SCM_GITHUB_API_BASE_URL=https://api.github.com
SCM_LOCAL_REPOSITORY_PATH=/absolute/path/to/local/repo-cloned-from-origin

# API runtime
API_PORT=8080
API_GRAPHQL_PATH=/query
API_PLAYGROUND_PATH=/
API_ENABLE_PLAYGROUND=true

# Worker runtime
WORKER_PORT=8081
