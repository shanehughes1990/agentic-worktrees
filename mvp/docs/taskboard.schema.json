{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-worktrees.local/schemas/taskboard.schema.json",
  "title": "Agentic Worktrees Taskboard Schema",
  "description": "Canonical board schema used by ingestion and execution pipelines. Structure is board -> epics -> tasks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "board_id",
    "run_id",
    "status",
    "epics",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "board_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/epic"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "not-started",
        "in-progress",
        "completed",
        "blocked"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "identifier_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "board_id",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "board_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "priority": {
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "created_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "task_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        },
        "task_branch": {
          "type": "string"
        },
        "worktree": {
          "type": "string"
        },
        "resume_session_id": {
          "type": "string"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "task": {
      "allOf": [
        {
          "$ref": "#/$defs/work_item"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "depends_on": {
              "$ref": "#/$defs/identifier_list"
            },
            "outcome": {
              "$ref": "#/$defs/task_outcome"
            }
          }
        }
      ]
    },
    "epic": {
      "allOf": [
        {
          "$ref": "#/$defs/work_item"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tasks"
          ],
          "properties": {
            "depends_on": {
              "$ref": "#/$defs/identifier_list"
            },
            "tasks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/task"
              }
            }
          }
        }
      ]
    }
  }
}